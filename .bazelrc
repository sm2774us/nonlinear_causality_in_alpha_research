build --compilation_mode=opt
build --copt=-O3
build --strip=never
build --incompatible_enable_cc_toolchain_resolution

# ── Linux / Ubuntu 24.04 (Clang-19 + libc++) ─────────────────────────────────
# CHANGED: Use -std=c++26 and remove -fmodules-ts to stop Clang 19 errors.
build:linux --cxxopt=-std=c++26
build:linux --copt=-march=native
build:linux --copt=-fexperimental-library
#build:linux --linkopt=-stdlib=libc++
#build:linux --linkopt=-lc++abi
#build:linux --action_env=CC=clang-19
#build:linux --action_env=CXX=clang++-19
# CRITICAL: -stdlib=libc++ must be in BOTH --cxxopt AND --linkopt.
# --cxxopt ensures ALL C++ translation units (including GoogleTest) are
# compiled against libc++ headers/ABI. Without this, GoogleTest is compiled
# with libstdc++ (Ubuntu default) while the engine uses libc++, causing an
# ABI mismatch and hundreds of undefined-reference errors at link time.
build:linux --cxxopt=-stdlib=libc++
build:linux --linkopt=-stdlib=libc++
build:linux --linkopt=-lc++abi
build:linux --action_env=CC=clang-19
build:linux --action_env=CXX=clang++-19

# ── Windows 11 (MSVC 19.40+) ─────────────────────────────────────────────────
build:windows --cxxopt=/std:c++latest
build:windows --copt=/utf-8
build:windows --copt=/W4
build:windows --copt=/arch:AVX2
build:windows --copt=/EHsc

# ── Python 3.13 ───────────────────────────────────────────────────────────────
build --python_version=PY3

# ── Test ──────────────────────────────────────────────────────────────────────
test --test_output=errors
test --test_timeout=120
