load("@rules_cc//cc:defs.bzl", "cc_library", "cc_test", "cc_binary")

# 1. Flags for your core Engine (.ixx logic)
ENGINE_FLAGS = select({
    "@platforms//os:linux": [
        "-std=c++26", 
        "-fimplicit-modules", 
        "-fexperimental-library",
        "-xc++",                # Force C++ interpretation for .ixx
        "-Wno-missing-braces",  # Suppress std::array subobject warnings
    ],
    "@platforms//os:windows": [
        "/std:c++latest",
        "/wd4849",              # MSVC equivalent for certain module warnings
    ],
})

# 2. Flags for the Bindings (No -xc++ here!)
BINDING_FLAGS = select({
    "@platforms//os:linux": [
        "-std=c++26", 
        "-fimplicit-modules", 
        "-fexperimental-library",
        "-Wno-missing-braces",  # Safe to keep
    ],
    "@platforms//os:windows": [
        "/std:c++latest",
        "/wd4849",
    ],
})

cc_library(
    name = "risk_kernel",
    srcs = [],
    # We put .ixx in hdrs so Bazel doesn't complain about the extension
    hdrs = ["RiskKernel.ixx", "RiskKernel.h"], 
    copts = ENGINE_FLAGS,
    visibility = ["//visibility:public"],
)

cc_library(
    name = "macro_alpha_engine",
    srcs = [],
    hdrs = ["MacroAlphaEngine.ixx", "MacroAlphaEngine.h"],
    deps = [":risk_kernel"],
    copts = ENGINE_FLAGS,
    visibility = ["//visibility:public"],
)

cc_binary(
    name = "alpha_engine_cpp.so",
    srcs = ["bindings.cpp"],
    linkshared = True,
    linkstatic = False,
    # CRITICAL: We do NOT use ENGINE_FLAGS here because nanobind 
    # headers are sensitive to the -xc++ flag during the binding phase.
	copts = BINDING_FLAGS, # <--- Clean cross-platform flags
    deps = [
        ":macro_alpha_engine",
        "@nanobind", 
    ],
)

cc_test(
    name = "alpha_engine_test",
    srcs = ["alpha_engine_test.cpp"],
    deps = [
        ":macro_alpha_engine", 
        "@googletest//:gtest_main"
    ],
    copts = ENGINE_FLAGS,
)